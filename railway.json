{
  "$schema": "https://railway.com/creators/schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "pip install -r requirements.txt && playwright install --with-deps chromium"
  },
  "deploy": {
    "startCommand": "gunicorn server:app",
    "healthCheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
